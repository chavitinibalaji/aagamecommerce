# Aagam production API environment template
# Copy values into Railway/VPS secrets. Do not commit real secrets.

NODE_ENV=production
PORT=3005

# Database and cache
DATABASE_URL=postgresql://USER:PASSWORD@HOST:PORT/DATABASE
REDIS_URL=redis://USER:PASSWORD@HOST:PORT

# Auth
JWT_SECRET=replace-with-at-least-32-random-characters
RIDER_BANK_ENCRYPTION_KEY=replace-with-a-separate-32-character-random-secret

# Browser clients allowed to call the API. Comma-separated.
CORS_ORIGINS=https://your-admin-domain.example.com,https://your-customer-domain.example.com

# Optional third-party providers used by enabled modules
SUPABASE_URL=
SUPABASE_ANON_KEY=
FIREBASE_PROJECT_ID=
AWS_REGION=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET=
R2_ENDPOINT=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=
R2_PUBLIC_URL=
R2_EVIDENCE_BUCKET_NAME=
