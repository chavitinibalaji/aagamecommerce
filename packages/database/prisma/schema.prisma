generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String   @id @default(cuid())
  email         String   @unique
  password      String?
  googleSub     String?
  phone         String?  @unique
  name          String?
  avatarUrl     String?
  emailVerified Boolean  @default(false)
  role          Role     @default(CUSTOMER)
  fcmToken      String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  riderProfile              RiderProfile?
  orders                    Order[]
  addresses                 CustomerAddress[]
  stores                    Store[]                  @relation("StoreOwner")
  pushSubscriptions         PushSubscription[]
  notificationRecipients    NotificationRecipient[]
  notificationPreferences   NotificationPreference[]
  promotionCampaignsCreated PromotionCampaign[]      @relation("PromotionCampaignCreatedBy")
  couponsCreated            Coupon[]                 @relation("CouponCreatedBy")
  couponRedemptions         CouponRedemption[]
}

enum Role {
  CUSTOMER
  RIDER
  ADMIN
  STORE_OWNER
}

model Store {
  id        String    @id @default(cuid())
  name      String
  address   String
  latitude  Float
  longitude Float
  isActive  Boolean   @default(true)
  deletedAt DateTime?
  ownerId   String
  owner     User      @relation("StoreOwner", fields: [ownerId], references: [id])
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  inventory        Inventory[]
  orders           Order[]
  inventoryLedgers InventoryLedger[]
  coupons          Coupon[]
}

model Category {
  id                  String                      @id @default(cuid())
  name                String                      @unique
  products            Product[]
  promotionCampaigns  PromotionCampaign[]
  couponEligibilities CouponCategoryEligibility[]
}

model Product {
  id          String    @id @default(cuid())
  name        String
  description String?
  price       Float
  pricePaise  Int       @default(0)
  image       String?
  images      Json?
  details     Json?
  isActive    Boolean   @default(true)
  deletedAt   DateTime?
  categoryId  String
  category    Category  @relation(fields: [categoryId], references: [id])
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  inventory           Inventory[]
  orderItems          OrderItem[]
  inventoryLedgers    InventoryLedger[]
  promotionCampaigns  PromotionCampaign[]
  couponEligibilities CouponProductEligibility[]
}

model Inventory {
  id        String   @id @default(cuid())
  storeId   String
  productId String
  quantity  Int      @default(0)
  store     Store    @relation(fields: [storeId], references: [id])
  product   Product  @relation(fields: [productId], references: [id])
  updatedAt DateTime @updatedAt

  @@unique([storeId, productId])
}

model Order {
  id               String        @id @default(cuid())
  customerId       String
  customer         User          @relation(fields: [customerId], references: [id])
  storeId          String
  store            Store         @relation(fields: [storeId], references: [id])
  status           OrderStatus   @default(PENDING)
  totalAmount      Float
  currency         String        @default("INR")
  subtotal         Float         @default(0)
  deliveryFee      Float         @default(0)
  discountAmount   Float         @default(0)
  taxAmount        Float         @default(0)
  grandTotal       Float         @default(0)
  subtotalPaise    Int           @default(0)
  deliveryFeePaise Int           @default(0)
  discountPaise    Int           @default(0)
  taxPaise         Int           @default(0)
  grandTotalPaise  Int           @default(0)
  deliveryLat      Float?
  deliveryLng      Float?
  idempotencyKey   String?       @unique
  customerSnapshot Json?
  addressSnapshot  Json?
  itemsSnapshot    Json?
  pricingSnapshot  Json?
  riderId          String?
  rider            RiderProfile? @relation(fields: [riderId], references: [id])
  confirmedAt      DateTime?
  pickingAt        DateTime?
  packedAt         DateTime?
  riderAssignedAt  DateTime?
  outForDeliveryAt DateTime?
  deliveredAt      DateTime?
  cancelledAt      DateTime?
  paymentFailedAt  DateTime?
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt

  items              OrderItem[]
  payment            Payment?
  refunds            Refund[]
  statusHistory      OrderStatusHistory[]
  riderLocationPings RiderLocationPing[]
  deliveryJob        DeliveryJob?
  pickupProof        PickupProof?
  deliveryProof      DeliveryProof?
  codLedger          CodLedger?
  failureDecisions   DeliveryFailureDecision[]
  notifications      Notification[]
  couponRedemption   CouponRedemption?
}

enum PromotionStatus {
  DRAFT
  SCHEDULED
  ACTIVE
  PAUSED
  ARCHIVED
}

enum PromotionPlacement {
  HOME_HERO
  HOME_TODAY_OFFERS
  DEALS_PAGE
}

enum PromotionTargetType {
  NONE
  PRODUCT
  CATEGORY
  DEALS
  INTERNAL_PATH
}

model PromotionCampaign {
  id              String                         @id @default(cuid())
  internalName    String
  title           String
  subtitle        String?
  description     String?
  badgeText       String?
  imageUrl        String?
  mobileImageUrl  String?
  backgroundColor String                         @default("#0f172a")
  textColor       String                         @default("#ffffff")
  accentColor     String                         @default("#14b8a6")
  ctaLabel        String                         @default("Shop now")
  targetType      PromotionTargetType            @default(DEALS)
  targetPath      String?
  productId       String?
  product         Product?                       @relation(fields: [productId], references: [id])
  categoryId      String?
  category        Category?                      @relation(fields: [categoryId], references: [id])
  couponId        String?
  coupon          Coupon?                        @relation(fields: [couponId], references: [id])
  status          PromotionStatus                @default(DRAFT)
  startsAt        DateTime?
  endsAt          DateTime?
  priority        Int                            @default(0)
  firstOrderOnly  Boolean                        @default(false)
  createdByUserId String
  createdBy       User                           @relation("PromotionCampaignCreatedBy", fields: [createdByUserId], references: [id])
  publishedAt     DateTime?
  createdAt       DateTime                       @default(now())
  updatedAt       DateTime                       @updatedAt
  placements      PromotionPlacementAssignment[]

  @@index([status, startsAt, endsAt])
  @@index([priority])
  @@index([productId])
  @@index([categoryId])
  @@index([couponId])
}

model PromotionPlacementAssignment {
  id         String             @id @default(cuid())
  campaignId String
  campaign   PromotionCampaign  @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  placement  PromotionPlacement
  sortOrder  Int                @default(0)
  createdAt  DateTime           @default(now())

  @@unique([campaignId, placement])
  @@index([placement, sortOrder])
}

enum CouponStatus {
  DRAFT
  SCHEDULED
  ACTIVE
  PAUSED
  ARCHIVED
}

enum CouponApplicationMode {
  CODE
  AUTO
}

enum CouponDiscountType {
  PERCENTAGE
  FIXED_AMOUNT
  FREE_DELIVERY
}

enum CouponEligibilityScope {
  ALL
  PRODUCTS
  CATEGORIES
}

enum CouponRedemptionStatus {
  RESERVED
  REDEEMED
  RELEASED
}

model Coupon {
  id                    String                      @id @default(cuid())
  code                  String                      @unique
  name                  String
  description           String?
  status                CouponStatus                @default(DRAFT)
  applicationMode       CouponApplicationMode       @default(CODE)
  discountType          CouponDiscountType
  percentageBps         Int?
  amountPaise           Int?
  maxDiscountPaise      Int?
  minimumSubtotalPaise  Int                         @default(0)
  startsAt              DateTime?
  endsAt                DateTime?
  totalUsageLimit       Int?
  perCustomerLimit      Int                         @default(1)
  firstOrderOnly        Boolean                     @default(false)
  eligibilityScope      CouponEligibilityScope      @default(ALL)
  priority              Int                         @default(0)
  storeId               String?
  store                 Store?                      @relation(fields: [storeId], references: [id])
  createdByUserId       String
  createdBy             User                        @relation("CouponCreatedBy", fields: [createdByUserId], references: [id])
  createdAt             DateTime                    @default(now())
  updatedAt             DateTime                    @updatedAt
  campaigns             PromotionCampaign[]
  productEligibilities  CouponProductEligibility[]
  categoryEligibilities CouponCategoryEligibility[]
  redemptions           CouponRedemption[]

  @@index([status, startsAt, endsAt])
  @@index([applicationMode, priority])
  @@index([storeId])
}

model CouponProductEligibility {
  couponId  String
  coupon    Coupon  @relation(fields: [couponId], references: [id], onDelete: Cascade)
  productId String
  product   Product @relation(fields: [productId], references: [id])

  @@id([couponId, productId])
  @@index([productId])
}

model CouponCategoryEligibility {
  couponId   String
  coupon     Coupon   @relation(fields: [couponId], references: [id], onDelete: Cascade)
  categoryId String
  category   Category @relation(fields: [categoryId], references: [id])

  @@id([couponId, categoryId])
  @@index([categoryId])
}

model CouponRedemption {
  id            String                 @id @default(cuid())
  couponId      String
  coupon        Coupon                 @relation(fields: [couponId], references: [id])
  customerId    String
  customer      User                   @relation(fields: [customerId], references: [id])
  orderId       String                 @unique
  order         Order                  @relation(fields: [orderId], references: [id])
  status        CouponRedemptionStatus @default(RESERVED)
  codeSnapshot  String
  discountPaise Int
  ruleSnapshot  Json
  reservedAt    DateTime               @default(now())
  redeemedAt    DateTime?
  releasedAt    DateTime?
  releaseReason String?

  @@index([couponId, status])
  @@index([customerId, couponId, status])
}

model OrderItem {
  id             String  @id @default(cuid())
  orderId        String
  productId      String
  quantity       Int
  price          Float
  unitPricePaise Int     @default(0)
  lineTotalPaise Int     @default(0)
  order          Order   @relation(fields: [orderId], references: [id])
  product        Product @relation(fields: [productId], references: [id])
}

model RiderProfile {
  id                       String                      @id @default(cuid())
  userId                   String                      @unique
  user                     User                        @relation(fields: [userId], references: [id])
  status                   RiderStatus                 @default(OFFLINE)
  latitude                 Float?
  longitude                Float?
  orders                   Order[]
  locationPings            RiderLocationPing[]
  deliveryJobs             DeliveryJob[]               @relation("DeliveryJobCurrentRider")
  dispatchAssignments      DispatchAssignment[]
  vehicleType              String?
  vehicleNumber            String?
  emergencyContactName     String?
  emergencyContactPhone    String?
  bankAccountCiphertext    String?
  bankIfscCiphertext       String?
  bankAccountLast4         String?
  bankStatus               RiderApprovalStatus         @default(PENDING)
  approvalStatus           RiderApprovalStatus         @default(PENDING)
  bankReviewedByUserId     String?
  bankReviewedAt           DateTime?
  approvalReviewedByUserId String?
  approvalReviewedAt       DateTime?
  availabilitySchedules    RiderAvailabilitySchedule[]
  shifts                   RiderShift[]
  breaks                   RiderBreak[]
  documents                RiderDocument[]
  earnings                 RiderEarning[]
  pickupTasks              RiderPickupTask[]
  pickupProofs             PickupProof[]
  deliveryProofs           DeliveryProof[]
  codLedgers               CodLedger[]
  supportTickets           RiderSupportTicket[]
  updatedAt                DateTime                    @updatedAt
}

enum OrderStatus {
  PENDING
  PAYMENT_PENDING
  PAYMENT_FAILED
  CONFIRMED
  PICKING
  PACKED
  RIDER_ASSIGNED
  OUT_FOR_DELIVERY
  DELIVERED
  CANCELLED
}

enum DeliveryJobStatus {
  WAITING_FOR_DISPATCH
  RIDER_ASSIGNED
  RIDER_EN_ROUTE_TO_STORE
  RIDER_AT_STORE
  PICKUP_VERIFIED
  OUT_FOR_DELIVERY
  RIDER_AT_CUSTOMER
  DELIVERED
  DELIVERY_FAILED
  RETURNING_TO_STORE
  RETURNED_TO_STORE
  CANCELLED
}

enum DispatchAssignmentStatus {
  CREATED
  OFFERED
  ACCEPTED
  REJECTED
  EXPIRED
  CANCELLED
  REASSIGNED
}

enum DeliveryEventType {
  JOB_CREATED
  JOB_STATUS_CHANGED
  ASSIGNMENT_CREATED
  ASSIGNMENT_OFFERED
  ASSIGNMENT_ACCEPTED
  ASSIGNMENT_REJECTED
  ASSIGNMENT_EXPIRED
  ASSIGNMENT_CANCELLED
  ASSIGNMENT_REASSIGNED
  LEGACY_ADAPTER_USED
}

model DeliveryJob {
  id             String            @id @default(cuid())
  orderId        String            @unique
  order          Order             @relation(fields: [orderId], references: [id], onDelete: Cascade)
  status         DeliveryJobStatus @default(WAITING_FOR_DISPATCH)
  currentRiderId String?
  currentRider   RiderProfile?     @relation("DeliveryJobCurrentRider", fields: [currentRiderId], references: [id], onDelete: SetNull)
  version        Int               @default(0)
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt

  assignments      DispatchAssignment[]
  events           DeliveryEvent[]
  pickupChallenges PickupChallenge[]
  pickupProof      PickupProof?
  deliveryProof    DeliveryProof?
  codLedger        CodLedger?
  failureDecisions DeliveryFailureDecision[]
  notifications    Notification[]

  @@index([status, createdAt])
  @@index([currentRiderId, status])
}

enum PickupVerificationMethod {
  STORE_PICKUP_PIN
  QR_CODE
  STORE_CONFIRMED_HANDOFF
}

enum PickupChallengeStatus {
  PENDING
  USED
  EXPIRED
  SUPERSEDED
  FAILED
}

enum DeliveryVerificationMethod {
  CUSTOMER_OTP_PIN
}

enum CodSettlementStatus {
  AWAITING_COLLECTION
  HELD_BY_RIDER
  PARTIALLY_DEPOSITED
  SETTLED
  VARIANCE_REVIEW
}

enum CodLedgerEntryType {
  EXPECTED
  COLLECTED
  DEPOSITED
  VARIANCE_RECORDED
}

enum DeliveryFailureReasonCode {
  CUSTOMER_UNREACHABLE
  CUSTOMER_REFUSED
  ADDRESS_NOT_FOUND
  WRONG_ADDRESS
  PAYMENT_NOT_AVAILABLE
  VEHICLE_BREAKDOWN
  PACKAGE_DAMAGED
  SAFETY_CONCERN
  OTHER
}

enum DeliveryResolutionAction {
  RETRY_DELIVERY
  REASSIGN_RIDER
  RETURN_TO_STORE
  CANCEL_AND_REFUND
  ESCALATE_TO_ADMIN
}

enum DeliveryResolutionStatus {
  DECIDED
  IN_PROGRESS
  COMPLETED
  SUPERSEDED
}

model PickupChallenge {
  id                  String                   @id @default(cuid())
  deliveryJobId       String
  deliveryJob         DeliveryJob              @relation(fields: [deliveryJobId], references: [id], onDelete: Cascade)
  method              PickupVerificationMethod
  codeHash            String
  salt                String
  issuedByStoreUserId String
  parcelCount         Int
  status              PickupChallengeStatus    @default(PENDING)
  attempts            Int                      @default(0)
  expiresAt           DateTime
  usedAt              DateTime?
  createdAt           DateTime                 @default(now())
  updatedAt           DateTime                 @updatedAt

  @@index([deliveryJobId, status, expiresAt])
}

model PickupProof {
  id                 String                   @id @default(cuid())
  deliveryJobId      String                   @unique
  deliveryJob        DeliveryJob              @relation(fields: [deliveryJobId], references: [id], onDelete: Cascade)
  orderId            String                   @unique
  order              Order                    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  riderId            String
  rider              RiderProfile             @relation(fields: [riderId], references: [id], onDelete: Restrict)
  storeUserId        String
  verifiedAt         DateTime                 @default(now())
  latitude           Float?
  longitude          Float?
  accuracyMetres     Float?
  parcelCount        Int
  verificationMethod PickupVerificationMethod
  challengeId        String?                  @unique
  createdAt          DateTime                 @default(now())

  @@index([riderId, verifiedAt])
  @@index([storeUserId, verifiedAt])
}

model DeliveryProof {
  id                 String                     @id @default(cuid())
  deliveryJobId      String                     @unique
  deliveryJob        DeliveryJob                @relation(fields: [deliveryJobId], references: [id], onDelete: Cascade)
  orderId            String                     @unique
  order              Order                      @relation(fields: [orderId], references: [id], onDelete: Cascade)
  riderId            String
  rider              RiderProfile               @relation(fields: [riderId], references: [id], onDelete: Restrict)
  customerUserId     String
  verificationMethod DeliveryVerificationMethod @default(CUSTOMER_OTP_PIN)
  otpOperationId     String
  riderConfirmedAt   DateTime
  verifiedAt         DateTime                   @default(now())
  note               String?
  latitude           Float?
  longitude          Float?
  accuracyMetres     Float?
  createdAt          DateTime                   @default(now())

  @@index([riderId, verifiedAt])
  @@index([customerUserId, verifiedAt])
}

model CodLedger {
  id                       String              @id @default(cuid())
  deliveryJobId            String              @unique
  deliveryJob              DeliveryJob         @relation(fields: [deliveryJobId], references: [id], onDelete: Cascade)
  orderId                  String              @unique
  order                    Order               @relation(fields: [orderId], references: [id], onDelete: Cascade)
  riderId                  String?
  rider                    RiderProfile?       @relation(fields: [riderId], references: [id], onDelete: Restrict)
  currency                 String              @default("INR")
  expectedAmountPaise      Int
  collectedAmountPaise     Int                 @default(0)
  collectionTimestamp      DateTime?
  riderHoldingBalancePaise Int                 @default(0)
  depositedAmountPaise     Int                 @default(0)
  settlementReference      String?
  variancePaise            Int                 @default(0)
  varianceReason           String?
  status                   CodSettlementStatus @default(AWAITING_COLLECTION)
  createdAt                DateTime            @default(now())
  updatedAt                DateTime            @updatedAt
  entries                  CodLedgerEntry[]

  @@index([riderId, status])
  @@index([status, updatedAt])
}

model CodLedgerEntry {
  id                  String             @id @default(cuid())
  codLedgerId         String
  codLedger           CodLedger          @relation(fields: [codLedgerId], references: [id], onDelete: Cascade)
  type                CodLedgerEntryType
  amountPaise         Int
  holdingAfterPaise   Int
  depositedAfterPaise Int
  actorUserId         String
  actorRole           Role
  reference           String?
  idempotencyKey      String             @unique
  metadata            Json?
  createdAt           DateTime           @default(now())

  @@index([codLedgerId, createdAt])
  @@index([actorUserId, createdAt])
}

model DeliveryFailureDecision {
  id                 String                    @id @default(cuid())
  deliveryJobId      String
  deliveryJob        DeliveryJob               @relation(fields: [deliveryJobId], references: [id], onDelete: Cascade)
  orderId            String
  order              Order                     @relation(fields: [orderId], references: [id], onDelete: Cascade)
  failureOperationId String                    @unique
  reason             DeliveryFailureReasonCode
  recommendedAction  DeliveryResolutionAction
  decidedAction      DeliveryResolutionAction
  status             DeliveryResolutionStatus  @default(DECIDED)
  policyVersion      String
  rationale          String
  decidedBy          String                    @default("SYSTEM")
  overriddenByUserId String?
  overrideReason     String?
  appliedByUserId    String?
  appliedAt          DateTime?
  createdAt          DateTime                  @default(now())
  updatedAt          DateTime                  @updatedAt

  @@index([deliveryJobId, createdAt])
  @@index([status, recommendedAction, createdAt])
}

model DispatchAssignment {
  id              String                   @id @default(cuid())
  deliveryJobId   String
  deliveryJob     DeliveryJob              @relation(fields: [deliveryJobId], references: [id], onDelete: Cascade)
  riderProfileId  String
  riderProfile    RiderProfile             @relation(fields: [riderProfileId], references: [id], onDelete: Cascade)
  status          DispatchAssignmentStatus @default(CREATED)
  offeredAt       DateTime?
  respondedAt     DateTime?
  expiresAt       DateTime?
  rejectionReason String?
  createdByUserId String?
  createdAt       DateTime                 @default(now())
  updatedAt       DateTime                 @updatedAt

  events DeliveryEvent[]

  @@index([deliveryJobId, status])
  @@index([riderProfileId, status])
  @@index([expiresAt, status])
}

model DeliveryEvent {
  id            String              @id @default(cuid())
  deliveryJobId String
  deliveryJob   DeliveryJob         @relation(fields: [deliveryJobId], references: [id], onDelete: Cascade)
  assignmentId  String?
  assignment    DispatchAssignment? @relation(fields: [assignmentId], references: [id], onDelete: SetNull)
  eventType     DeliveryEventType
  fromStatus    DeliveryJobStatus?
  toStatus      DeliveryJobStatus?
  actorUserId   String?
  actorRole     Role?
  metadata      Json?
  createdAt     DateTime            @default(now())

  @@index([deliveryJobId, createdAt])
  @@index([assignmentId, createdAt])
  @@index([eventType, createdAt])
}

model OrderStatusHistory {
  id          String       @id @default(cuid())
  orderId     String
  order       Order        @relation(fields: [orderId], references: [id], onDelete: Cascade)
  fromStatus  OrderStatus?
  toStatus    OrderStatus
  actorUserId String?
  actorRole   Role?
  note        String?
  metadata    Json?
  createdAt   DateTime     @default(now())

  @@index([orderId, createdAt])
}

model RiderLocationPing {
  id             String       @id @default(cuid())
  riderProfileId String
  riderProfile   RiderProfile @relation(fields: [riderProfileId], references: [id], onDelete: Cascade)
  orderId        String
  order          Order        @relation(fields: [orderId], references: [id], onDelete: Cascade)
  latitude       Float
  longitude      Float
  accuracy       Float?
  speed          Float?
  heading        Float?
  source         String       @default("MOBILE")
  createdAt      DateTime     @default(now())

  @@index([orderId, createdAt])
  @@index([riderProfileId, createdAt])
}

model CustomerAddress {
  id                 String   @id @default(cuid())
  userId             String
  user               User     @relation(fields: [userId], references: [id])
  label              String?
  recipientName      String
  phoneE164          String
  alternatePhoneE164 String?
  line1              String
  line2              String?
  landmark           String?
  city               String
  state              String
  pincode            String
  country            String   @default("IN")
  latitude           Float
  longitude          Float
  instructions       String?
  isDefault          Boolean  @default(false)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
}

enum PaymentMethod {
  ONLINE
  COD
}

enum PaymentStatus {
  CREATED
  CAPTURED
  FAILED
  PENDING_COD
  REFUND_PENDING
  REFUNDED
}

model Payment {
  id                String        @id @default(cuid())
  orderId           String        @unique
  order             Order         @relation(fields: [orderId], references: [id])
  method            PaymentMethod
  status            PaymentStatus @default(CREATED)
  provider          String        @default("SIMULATED")
  amount            Float
  amountPaise       Int           @default(0)
  currency          String        @default("INR")
  idempotencyKey    String?       @unique
  providerOrderId   String?
  providerPaymentId String?
  verifiedAt        DateTime?
  failureReason     String?
  refunds           Refund[]
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt
}

enum RefundStatus {
  PENDING
  PROCESSED
  FAILED
}

model Refund {
  id                String       @id @default(cuid())
  orderId           String
  order             Order        @relation(fields: [orderId], references: [id])
  paymentId         String
  payment           Payment      @relation(fields: [paymentId], references: [id])
  amountPaise       Int
  status            RefundStatus @default(PENDING)
  reason            String
  providerRefundId  String?
  requestedByUserId String?
  processedAt       DateTime?
  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt

  @@index([orderId])
  @@index([paymentId])
}

enum RiderStatus {
  ONLINE
  OFFLINE
  BUSY
}

enum RiderApprovalStatus {
  PENDING
  APPROVED
  REJECTED
  EXPIRED
}

enum RiderShiftStatus {
  SCHEDULED
  ACTIVE
  COMPLETED
  CANCELLED
}

enum RiderBreakStatus {
  ACTIVE
  ENDED
}

enum RiderDocumentType {
  DRIVING_LICENSE
  IDENTITY
  VEHICLE_REGISTRATION
  VEHICLE_INSURANCE
  OTHER
}

enum RiderEarningType {
  BASE_DELIVERY_FEE
  DISTANCE_INCENTIVE
  BONUS
  PENALTY
}

enum RiderEarningStatus {
  PENDING
  PAID
}

enum RiderPickupStatus {
  PENDING
  VERIFIED
  PROBLEM_REPORTED
}

enum RiderSupportStatus {
  OPEN
  IN_PROGRESS
  RESOLVED
  CLOSED
}

model RiderAvailabilitySchedule {
  id             String       @id @default(cuid())
  riderProfileId String
  riderProfile   RiderProfile @relation(fields: [riderProfileId], references: [id], onDelete: Cascade)
  dayOfWeek      Int
  startMinute    Int
  endMinute      Int
  isAvailable    Boolean      @default(true)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@unique([riderProfileId, dayOfWeek, startMinute, endMinute])
  @@index([riderProfileId, dayOfWeek])
}

model RiderShift {
  id              String           @id @default(cuid())
  riderProfileId  String
  riderProfile    RiderProfile     @relation(fields: [riderProfileId], references: [id], onDelete: Cascade)
  startsAt        DateTime
  endsAt          DateTime
  status          RiderShiftStatus @default(SCHEDULED)
  actualStartedAt DateTime?
  actualEndedAt   DateTime?
  note            String?
  createdByUserId String?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  @@index([riderProfileId, startsAt])
  @@index([status, startsAt])
}

model RiderBreak {
  id             String           @id @default(cuid())
  riderProfileId String
  riderProfile   RiderProfile     @relation(fields: [riderProfileId], references: [id], onDelete: Cascade)
  status         RiderBreakStatus @default(ACTIVE)
  reason         String?
  startedAt      DateTime         @default(now())
  endedAt        DateTime?

  @@index([riderProfileId, status, startedAt])
}

model RiderDocument {
  id                  String              @id @default(cuid())
  riderProfileId      String
  riderProfile        RiderProfile        @relation(fields: [riderProfileId], references: [id], onDelete: Cascade)
  type                RiderDocumentType
  documentNumberLast4 String?
  storageKey          String
  expiresAt           DateTime?
  status              RiderApprovalStatus @default(PENDING)
  reviewNote          String?
  reviewedByUserId    String?
  reviewedAt          DateTime?
  createdAt           DateTime            @default(now())
  updatedAt           DateTime            @updatedAt

  @@index([riderProfileId, type, status])
  @@index([expiresAt])
}

model RiderEarning {
  id              String             @id @default(cuid())
  riderProfileId  String
  riderProfile    RiderProfile       @relation(fields: [riderProfileId], references: [id], onDelete: Cascade)
  deliveryJobId   String?
  type            RiderEarningType
  amountPaise     Int
  status          RiderEarningStatus @default(PENDING)
  reference       String?
  createdByUserId String?
  paidByUserId    String?
  earnedAt        DateTime           @default(now())
  paidAt          DateTime?
  createdAt       DateTime           @default(now())

  @@unique([deliveryJobId, type, reference])
  @@index([riderProfileId, earnedAt])
  @@index([riderProfileId, status])
}

model RiderPickupTask {
  id             String            @id @default(cuid())
  riderProfileId String
  riderProfile   RiderProfile      @relation(fields: [riderProfileId], references: [id], onDelete: Cascade)
  deliveryJobId  String            @unique
  status         RiderPickupStatus @default(PENDING)
  parcelCode     String?
  checklist      Json
  problemType    String?
  problemNote    String?
  verifiedAt     DateTime?
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt

  @@index([riderProfileId, status])
}

model RiderSupportTicket {
  id             String                @id @default(cuid())
  riderProfileId String
  riderProfile   RiderProfile          @relation(fields: [riderProfileId], references: [id], onDelete: Cascade)
  deliveryJobId  String?
  category       String
  subject        String
  description    String
  evidenceKeys   Json?
  status         RiderSupportStatus    @default(OPEN)
  createdAt      DateTime              @default(now())
  updatedAt      DateTime              @updatedAt
  messages       RiderSupportMessage[]

  @@index([riderProfileId, status, createdAt])
  @@index([deliveryJobId])
}

model RiderSupportMessage {
  id           String             @id @default(cuid())
  ticketId     String
  ticket       RiderSupportTicket @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  senderUserId String
  senderRole   Role
  body         String
  evidenceKeys Json?
  createdAt    DateTime           @default(now())

  @@index([ticketId, createdAt])
}

enum InventoryAdjustmentReason {
  MANUAL_ADJUSTMENT
  CHECKOUT_RESERVATION
  ORDER_CANCEL_RESTORE
  ORDER_DELIVERED_FINALIZE
  STOCK_CORRECTION
}

model InventoryLedger {
  id               String                    @id @default(cuid())
  storeId          String
  productId        String
  orderId          String?
  reason           InventoryAdjustmentReason
  quantityDelta    Int
  previousQuantity Int
  newQuantity      Int
  actorUserId      String?
  note             String?
  createdAt        DateTime                  @default(now())
  store            Store                     @relation(fields: [storeId], references: [id])
  product          Product                   @relation(fields: [productId], references: [id])

  @@index([storeId, createdAt])
  @@index([productId, createdAt])
  @@index([orderId])
}

enum PushProvider {
  FCM_WEB
  FCM_MOBILE
  WEB_PUSH
}

enum NotificationEventType {
  ORDER_PLACED
  STORE_ACCEPTED_ORDER
  STORE_STARTED_PICKING
  ORDER_PACKED
  DISPATCH_JOB_CREATED
  ASSIGNMENT_OFFERED
  ASSIGNMENT_ACCEPTED
  ASSIGNMENT_REJECTED
  ASSIGNMENT_EXPIRED
  RIDER_EN_ROUTE_TO_STORE
  RIDER_AT_STORE
  PICKUP_VERIFIED
  OUT_FOR_DELIVERY
  RIDER_AT_CUSTOMER
  DELIVERY_COMPLETED
  DELIVERY_FAILED
  DELIVERY_CANCELLED
  ADMIN_BROADCAST
}

enum OutboxStatus {
  PENDING
  PROCESSING
  PROCESSED
  FAILED
}

enum NotificationRecipientStatus {
  QUEUED
  SENT
  FAILED
  OPENED
  READ
}

enum NotificationAttemptStatus {
  PENDING
  SENT
  FAILED
  SKIPPED
}

model PushSubscription {
  id            String       @id @default(cuid())
  userId        String
  user          User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  provider      PushProvider @default(FCM_WEB)
  token         String?      @unique
  endpoint      String?
  p256dh        String?
  auth          String?
  userAgent     String?
  deviceName    String?
  isActive      Boolean      @default(true)
  lastSeenAt    DateTime     @default(now())
  invalidatedAt DateTime?
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  attempts NotificationDeliveryAttempt[]

  @@unique([provider, endpoint])
  @@index([userId, isActive])
  @@index([provider, isActive])
}

model NotificationPreference {
  id           String   @id @default(cuid())
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  eventType    String   @default("*")
  pushEnabled  Boolean  @default(true)
  inAppEnabled Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@unique([userId, eventType])
}

model OutboxEvent {
  id             String                @id @default(cuid())
  eventType      NotificationEventType
  aggregateType  String
  aggregateId    String
  payload        Json
  idempotencyKey String                @unique
  status         OutboxStatus          @default(PENDING)
  attempts       Int                   @default(0)
  availableAt    DateTime              @default(now())
  lockedAt       DateTime?
  processedAt    DateTime?
  lastError      String?
  createdAt      DateTime              @default(now())
  updatedAt      DateTime              @updatedAt

  notification Notification? @relation("OutboxNotification")

  @@index([status, availableAt])
  @@index([aggregateType, aggregateId])
}

model Notification {
  id            String                @id @default(cuid())
  eventType     NotificationEventType
  title         String
  body          String
  data          Json?
  deepLink      String?
  orderId       String?
  order         Order?                @relation(fields: [orderId], references: [id], onDelete: Cascade)
  deliveryJobId String?
  deliveryJob   DeliveryJob?          @relation(fields: [deliveryJobId], references: [id], onDelete: Cascade)
  outboxEventId String?               @unique
  outboxEvent   OutboxEvent?          @relation("OutboxNotification", fields: [outboxEventId], references: [id], onDelete: SetNull)
  createdAt     DateTime              @default(now())

  recipients NotificationRecipient[]

  @@index([eventType, createdAt])
  @@index([orderId, createdAt])
  @@index([deliveryJobId, createdAt])
}

model NotificationRecipient {
  id             String                      @id @default(cuid())
  notificationId String
  notification   Notification                @relation(fields: [notificationId], references: [id], onDelete: Cascade)
  userId         String
  user           User                        @relation(fields: [userId], references: [id], onDelete: Cascade)
  status         NotificationRecipientStatus @default(QUEUED)
  dedupeKey      String                      @unique
  sentAt         DateTime?
  openedAt       DateTime?
  readAt         DateTime?
  failedAt       DateTime?
  failureReason  String?
  createdAt      DateTime                    @default(now())
  updatedAt      DateTime                    @updatedAt

  attempts NotificationDeliveryAttempt[]

  @@unique([notificationId, userId])
  @@index([userId, status, createdAt])
}

model NotificationDeliveryAttempt {
  id             String                    @id @default(cuid())
  recipientId    String
  recipient      NotificationRecipient     @relation(fields: [recipientId], references: [id], onDelete: Cascade)
  subscriptionId String?
  subscription   PushSubscription?         @relation(fields: [subscriptionId], references: [id], onDelete: SetNull)
  attemptNumber  Int                       @default(1)
  status         NotificationAttemptStatus @default(PENDING)
  provider       PushProvider
  responseId     String?
  errorCode      String?
  errorMessage   String?
  nextRetryAt    DateTime?
  createdAt      DateTime                  @default(now())
  updatedAt      DateTime                  @updatedAt

  @@unique([recipientId, subscriptionId, attemptNumber])
  @@index([recipientId, createdAt])
  @@index([status, nextRetryAt])
}
