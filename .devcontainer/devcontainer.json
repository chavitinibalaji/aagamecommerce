{
  "image": "mcr.microsoft.com/devcontainers/javascript-node:20",
  "postCreateCommand": "bash .devcontainer/setup.sh",
  "forwardPorts": [3001, 3005, 5432, 6379],
  "portsAttributes": {
    "3001": {
      "visibility": "public"
    },
    "3005": {
      "visibility": "public"
    }
  },
  "containerEnv": {
    "DATABASE_URL": "postgresql://postgres:postgres@localhost:5432/aagam_ecom",
    "NODE_ENV": "development"
  },
  "remoteUser": "root"
}