# ================================================
# AAGAM E-Commerce Environment Variables
# ================================================
# Copy this file to .env and fill in the values
# NEVER commit .env to version control!

# ================================================
# REQUIRED - Security
# ================================================

# JWT Secret - Generate a strong random string (min 32 chars)
# Example: openssl rand -hex 32
JWT_SECRET=change-this-to-a-strong-random-string-min-32-chars

# Browser authentication is cookie-only through /auth/login and /auth/google.
# Native apps use /auth/mobile/login and /auth/mobile/google, then store the
# returned bearer token in the platform Keychain. Never expose a browser token
# through NEXT_PUBLIC variables or store it in localStorage.

# ================================================
# REQUIRED - Database
# ================================================

# PostgreSQL connection string (add ?sslmode=require for production)
DATABASE_URL=postgresql://user:password@localhost:5432/aagam_ecom?schema=public
# For production: postgresql://user:password@host:5432/aagam?sslmode=require

# ================================================
# OPTIONAL - Supabase (for later production)
# ================================================

# SUPABASE_URL=https://your-project.supabase.co
# SUPABASE_ANON_KEY=your-supabase-anon-key

# ================================================
# OPTIONAL - Redis (auto-fallback if not available)
# ================================================

# REDIS_URL=redis://localhost:6379

# ================================================
# OPTIONAL - Environment & CORS
# ================================================

# NODE_ENV=development
# PORT=3005
# CORS_ORIGINS=http://localhost:3001
# NEXT_PUBLIC_API_URL=http://localhost:3005

# Cloudflare R2 / S3-compatible storage. Product images use the public bucket;
# Rider identity and support evidence must use a separate private bucket.
R2_ENDPOINT=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=
R2_PUBLIC_URL=
R2_EVIDENCE_BUCKET_NAME=

# ================================================
# OPTIONAL - Google Sign-In
# ================================================

# OAuth 2.0 Web client ID (used by web login and mobile SDK to mint ID token)
# NEXT_PUBLIC_GOOGLE_WEB_CLIENT_ID is required on the web app deployment environment.
GOOGLE_WEB_CLIENT_ID=

# OAuth 2.0 Android client ID (audience accepted by backend token verifier)
GOOGLE_ANDROID_CLIENT_ID=

# Optional: required only if implementing Google auth code exchange on server
# GOOGLE_CLIENT_SECRET=

# ================================================
# PHASE 1 - Firebase Web Push
# ================================================

# Server credential used by Firebase Admin to send notifications. Prefer the
# single-line JSON environment variable in hosted environments. A local
# firebase-adminsdk.json file is also supported but must never be committed.
FIREBASE_SERVICE_ACCOUNT_JSON=

# Canonical Firebase web configuration. Configure these on the API service.
# The authenticated /notifications/push/config endpoint returns the public
# values to the browser, and the browser passes that exact config to the
# service-worker registration. The dashboard does not need a duplicate config.
FIREBASE_WEB_API_KEY=
FIREBASE_WEB_AUTH_DOMAIN=
FIREBASE_WEB_PROJECT_ID=
FIREBASE_WEB_STORAGE_BUCKET=
FIREBASE_WEB_MESSAGING_SENDER_ID=
FIREBASE_WEB_APP_ID=
FIREBASE_WEB_VAPID_KEY=

# Optional dashboard-side fallback for manually opening the service-worker URL.
# Normal "Enable background alerts" registration does not depend on these.
# NEXT_PUBLIC_FIREBASE_API_KEY=
# NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
# NEXT_PUBLIC_FIREBASE_PROJECT_ID=
# NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
# NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
# NEXT_PUBLIC_FIREBASE_APP_ID=

# Notification worker defaults to 10 seconds and is disabled automatically in
# NODE_ENV=test.
# NOTIFICATION_WORKER_INTERVAL_MS=10000
# NOTIFICATION_WORKER_DISABLED=false

# ================================================
# PHASE 3 - Delivery Handoff and COD Controls
# ================================================

# Use a strong random secret in every production environment. It is used to
# derive short-lived delivery verification codes. Never reuse JWT_SECRET.
DELIVERY_OTP_SECRET=change-this-to-a-different-strong-random-string

# Separate secret used to AES-GCM encrypt Rider bank details at rest.
# Generate independently from JWT_SECRET and DELIVERY_OTP_SECRET.
RIDER_BANK_ENCRYPTION_KEY=change-this-to-another-strong-random-string

# When true, a rider cannot complete delivery until the customer OTP is verified.
DELIVERY_OTP_REQUIRED=false

# When true, a COD order cannot be completed until the exact amount is collected.
COD_COLLECTION_REQUIRED=false

# ================================================
# LOCAL PLAYWRIGHT QA - never commit real passwords
# ================================================

# QA_ADMIN_EMAIL=
# QA_ADMIN_PASSWORD=
# QA_CUSTOMER_EMAIL=
# QA_CUSTOMER_PASSWORD=
# QA_STORE_EMAIL=
# QA_STORE_PASSWORD=
# QA_RIDER_EMAIL=
# QA_RIDER_PASSWORD=

# ================================================
# PRODUCTION VALUES (do not use in development)
# ================================================
# NODE_ENV=production
# CORS_ORIGINS=https://yourdomain.com
# PORT=3005
